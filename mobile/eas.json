{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_API_BASE": "http://10.0.2.2:8000/api/v1" }
    },
    "preview": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_API_BASE": "https://staging-api.twinmatch.app/api/v1" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_API_BASE": "https://api.twinmatch.app/api/v1" }
    }
  },
  "submit": {
    "production": {
      "android": { "track": "internal" },
      "ios": {}
    }
  }
}
