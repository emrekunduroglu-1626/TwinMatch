{
  "expo": {
    "name": "TwinMatch",
    "slug": "twinmatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "twinmatch",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.twinmatch.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Selfie doğrulaması ve profil fotoğrafı çekimi için kameraya erişim gereklidir.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı ve videosu yüklemek için fotoğraf kitaplığına erişim gereklidir.",
        "NSLocationWhenInUseUsageDescription": "Yakınınızdaki güvenli buluşma mekanlarını göstermek için konumunuz kullanılır.",
        "NSFaceIDUsageDescription": "Hesabınıza güvenli ve hızlı giriş için Face ID kullanılır."
      }
    },
    "android": {
      "package": "com.twinmatch.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1020"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS"
      ],
      "allowBackup": false
    },
    "plugins": ["expo-secure-store", "expo-font"],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
